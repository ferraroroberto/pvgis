# Copy to `.env` (gitignored) and fill in your own house's details.
# The PV Estimator form is pre-filled from these values.

# App
APP_NAME=PVGIS House Estimator
DEBUG=0

# PVGIS API base (override only to pin a version; default is v5_3)
# PVGIS_API_BASE=https://re.jrc.ec.europa.eu/api/v5_3

# Your house (defaults below are central Madrid — replace with your roof)
HOME_LAT=40.4168
HOME_LON=-3.7038
HOME_PEAKPOWER_KW=4.0
HOME_LOSS_PCT=14.0
HOME_TILT_DEG=35.0
# Azimuth: 0 = south, -90 = east, 90 = west
HOME_AZIMUTH_DEG=0.0
